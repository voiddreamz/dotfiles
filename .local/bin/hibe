#!/usr/bin/sh
# @author nate zhou
# @since 2024,2025
# hibernate with a wmenu warning prompt

if [ "$XDG_RUNTIME_DIR" = "wayland" ]; then
    menu="${HOME}/.local/bin/wmenu-color"
elif [ -n "$XAUTHORITY" ]; then
    menu="dmenu"
fi

user_choice="$(printf "no\nyes" | $menu -p "System Suspend?")"

[ "$user_choice" = "yes" ] && systemctl suspend || exit 0
