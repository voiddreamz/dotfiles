#!/usr/bin/sh
# @author nate zhou
# @since 2025,2026
# river-classic/rules

add="riverctl rule-add"

$add -app-id "*" ssd   # draw boarders for every window

$add -title "Floating_Term" float
$add -title "Floating_Term" dimensions 956 717

$add -app-id "Floating_IMG" float
$add -app-id "Floating_IMG" dimensions 956 717

# GIMP
$add -app-id "file-*" float # file import/export
$add -app-id "script-fu" float # gegl operations
$add -app-id "lighting" -title "Lighting Effects" float

# kdenlive
$add -app-id "kdenlive" float # file chooser

$add -app-id "electron" -title "Open Folder" float #code-oss

$add -app-id "org.fcitx.fcitx5-config-qt" float

# Workspace assignments
# foot (all terminal apps) → workspace 1
$add -app-id "foot" tags 1

# Obsidian → workspace 2
$add -app-id "obsidian" tags 2

# Scrivano → workspace 3 (tag value: 4)
$add -app-id "Scrivano" tags 4

# qutebrowser → workspace 4 (tag value: 8)
$add -app-id "qutebrowser" tags 8
