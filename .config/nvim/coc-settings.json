{
  "suggest.signatureHelp.enable": true,
  "snippets.userSnippetsDirectory": "~/.config/nvim/snippets",

  "languageserver": {
    "typst": {
      "command": "tinymist",
      "args": ["lsp"],
      "filetypes": ["typst"],
      "rootPatterns": ["typst.toml", ".git"],
      "settings": {
        "exportPdf": "onType",
        "outputPath": "$root/$dir/$name",
        "formatterMode": "typstyle"
      }
    }
  },

  "clangd.path": "clangd",
  "python.formatting.provider": "black",
  "zig.zls.path": "/home/voiddreamz/.config/coc/extensions/coc-zls-data/zls_install/zls",
  "snippets.ultisnips.pythonPrompt": false
}
